# Ruta absoluta a la carpeta principal con las imágenes
# Ejemplos:
#   Windows: IMAGES_DIR=C:/MiCarpetaDeFotos
#   Linux/Mac: IMAGES_DIR=/home/usuario/fotos
#   Docker: se monta automáticamente en /data
IMAGES_DIR=

# Puerto del servidor backend (opcional, default: 3001)
PORT=3001

# Host para escuchar (opcional, default: 0.0.0.0)
# En Docker usar 0.0.0.0 para acceder desde fuera del contenedor
HOST=0.0.0.0

# Autenticación básica (opcional — ⚠️ SOLO ACTIVAR SOBRE HTTPS)
# Las credenciales viajan en Base64 (texto plano) si se usa HTTP.
ENABLE_AUTH=false
# AUTH_USER=usuario_seguro
# AUTH_PASS=contraseña_fuerte

# ⚠️ SECURITY WARNING:
# If ENABLE_AUTH=true and AUTH_PASS is still "changeme", the server will REFUSE TO START.
# Always set a strong password before enabling authentication.
# Basic Auth sends credentials in Base64 — use behind HTTPS in production.

# Nivel de logging (debug, info, warn, error)
LOG_LEVEL=info

# Entorno (development | production)
# 'development': logs bonitos con pino-pretty
# 'production':  logs JSON estructurados (ideal para Docker)
NODE_ENV=development
